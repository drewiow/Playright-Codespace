<main class="runner-layout" id="runnerRoot">

    <!-- WIZARD / CONFIGURATION AREA -->
    <aside class="wizard-shell">

        <!-- SCRIPT TITLE -->
        <h1 id="scriptTitle" class="script-title"></h1>

        <!-- PRE-WIZARD OVERVIEW -->
        <section id="scriptOverview">
            <h3>What does this script do?</h3>

            <div id="descriptionContent"></div>

            <button type="button" id="startWizardBtn" class="button-primary">
                Start setup
            </button>
        </section>

        <!-- WIZARD -->
        <section id="wizardContainer" class="hidden">

            <!-- WIZARD HEADER -->
            <header id="wizardHeader" class="wizard-header"></header>

            <!-- WIZARD FORM -->
            <form id="run-form" class="wizard-form">

                <!-- STEP: ENV -->
                <section id="envPanel" class="wizard-step">
                    <div class="field">
                        <label>Encrypted Details File</label>
                        <input type="file" id="runnerEnvFile" accept=".enc">
                    </div>

                    <div class="field">
                        <label>Decrypt Password</label>
                        <input type="password" id="decryptPassword">
                    </div>
                </section>

                <!-- STEP: CSV -->
                <section id="csvPanel" class="wizard-step">
                    <div class="field">
                        <label>CSV File</label>
                        <input type="file" id="csvFile" accept=".csv">
                    </div>
                </section>

                <!-- STEP: SCRIPT INPUTS -->
                <section id="inputsPanel" class="wizard-step">
                    <div id="scriptInputs"></div>
                </section>

                <!-- STEP: ACTIONS -->
                <section id="actionsPanel" class="wizard-step">


                    <div class="advanced-steps">

                        <textarea id="advancedSteps" rows="10" placeholder="click #save
wait 500"></textarea>

                        <!-- Optional helpers below the editor -->
                        <div class="advanced-inline-tools">

                            <div class="advanced-templates">
                                <label>
                                    Templates
                                    <select id="advancedTemplateSelect">
                                        <option value="">— Choose a template —</option>
                                    </select>
                                </label>
                            </div>

                            <div class="advanced-actions">
                                <strong>Actions</strong>
                                <div id="advancedActions"></div>
                            </div>

                            <div class="advanced-tokens">
                                <strong>Tokens</strong>
                                <div class="token-list" id="advancedTokenList"></div>
                            </div>

                        </div>
                    </div>
                </section>

                <!-- STEP: BEHAVIOUR -->
                <section id="behaviourPanel" class="wizard-step">
                    <div class="field">

                        <label>
                            <input type="checkbox" id="dryRunCheckbox" checked>
                            Dry run (no changes will be made)
                        </label>
                    </div>
                    <div class="field">
                        <label>
                            <input type="checkbox" id="showBrowser" checked>
                            Show Browser
                        </label>
                    </div>
                    <div class="field">
                        <label>
                            <input type="checkbox" id="humanMode">
                            Human-like mode (adds random delays and more human behaviour)
                        </label>
                    </div>
                    <div class="field">
                        <label>
                            <input type="range" id="humanIntensity" min="1" max="10" value="5">
                            Human Intensity
                        </label>
                    </div>

                    <div class="field">
                        <label>
                            <input type="checkbox" id="recordVideo">
                            Record Video
                        </label>
                    </div>
                    <div class="field">
                        <label>
                            <input type="checkbox" id="recordTrace">
                            Record Trace
                        </label>
                    </div>
                </section>

                <!-- STEP: REVIEW -->
                <section id="reviewPanel" class="wizard-step">
                    <h3>Review configuration</h3>

                    <div class="review-section">
                        <h4>Script</h4>
                        <div id="reviewScriptName"></div>
                    </div>

                    <div class="review-section">
                        <h4>Inputs</h4>
                        <div id="reviewInputs"></div>
                    </div>

                    <div class="review-section" id="reviewOptionsSection">
                        <h4>Options</h4>
                        <div id="reviewOptions"></div>
                    </div>
                </section>

                <!-- WIZARD NAVIGATION -->
                <nav class="wizard-nav">
                    <button type="button" id="wizardBackBtn">
                        ← Back
                    </button>

                    <button type="button" id="wizardNextBtn">
                        Next →
                    </button>

                    <button type="submit" id="runScriptBtn">
                        Run
                    </button>
                </nav>

            </form>
        </section>

    </aside>

    <!-- EXECUTION / LOGS AREA -->
    <aside class="execution-column hidden" id="executionContainer">

        <h2>Logs</h2>

        <div id="logContainer" class="log-viewer"></div>

        <div id="stopRunContainer" class="hidden">
            <button id="stopRunButton" class="stop-run-btn">
                🛑 Stop Run
            </button>
        </div>

        <section class="hidden" id="artifactSection">
            <h3>Run Artifacts</h3>
            <ul id="artifactList"></ul>
        </section>

    </aside>

</main>

<script type="module" src="/scripts/runner.js"></script>